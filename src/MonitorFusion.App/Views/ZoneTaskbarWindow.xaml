<Window x:Class="MonitorFusion.App.Views.ZoneTaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Height="36">

    <Border Background="#CC151520" CornerRadius="0,0,6,6" BorderThickness="0,1,0,0"
            BorderBrush="#44AAAAFF">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Zone name badge -->
            <Border Grid.Column="0" Background="#2A2A4A" CornerRadius="0,0,0,6"
                    Padding="8,0" Margin="0,0,4,0">
                <TextBlock x:Name="ZoneNameLabel"
                           Foreground="#88AAAAFF" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Window buttons -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="WindowPanel" Orientation="Horizontal" Margin="2,0"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
