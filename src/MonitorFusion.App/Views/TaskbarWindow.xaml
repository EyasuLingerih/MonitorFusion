<Window x:Class="MonitorFusion.App.Views.TaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MonitorFusion Taskbar" 
        Icon="/Assets/icon.png"
        WindowStyle="None" ResizeMode="NoResize" 
        AllowsTransparency="True" Background="#E611111E"
        ShowInTaskbar="False" Topmost="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Start Button Placeholder -->
        <Button Grid.Column="0" Width="48" Background="Transparent" BorderThickness="0">
            <Path Data="M 10 10 L 30 15 L 30 35 L 10 32 Z M 32 15 L 50 10 L 50 38 L 32 35 Z M 10 33 L 30 36 L 30 55 L 10 50 Z M 32 36 L 50 40 L 50 60 L 32 55 Z" 
                  Fill="#00A2ED" Stretch="Uniform" Margin="12"/>
        </Button>

        <!-- Taskbar Items Area -->
        <!-- In the future, this is where we would list open window tabs/icons -->
        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" x:Name="TaskbarIconsPanel" VerticalAlignment="Center">
                <!-- Example Placeholder -->
                <TextBlock Text="MonitorFusion" Foreground="{StaticResource TextSecondaryBrush}" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Tray / Clock Area -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
            <TextBlock x:Name="ClockText" Foreground="{StaticResource TextBrush}" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <!-- Top Border accent line depending on setting -->
        <Border Grid.ColumnSpan="3" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
