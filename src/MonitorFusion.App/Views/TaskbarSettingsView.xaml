<UserControl x:Class="MonitorFusion.App.Views.TaskbarSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,10,0">
            <!-- Header -->
            <TextBlock Text="Multi-Monitor Taskbar"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Adds a custom taskbar to your secondary monitors. Note: This feature places a borderless window that reserves screen space mimicking the Windows taskbar." 
                       TextWrapping="Wrap" Margin="0,0,0,20" Foreground="{StaticResource TextSecondaryBrush}"/>
            
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="General Settings" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <CheckBox x:Name="EnabledCheck" Content="Enable Multi-Monitor Taskbar" Foreground="{StaticResource TextBrush}" Margin="0,0,0,15" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                    
                    <StackPanel IsEnabled="{Binding ElementName=EnabledCheck, Path=IsChecked}">
                        <CheckBox x:Name="ShowAllMonitorsCheck" Content="Show on All Monitors (including Primary)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        <CheckBox x:Name="ShowClockCheck" Content="Show Clock" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20" Checked="Setting_Changed" Unchecked="Setting_Changed"/>

                        <!-- Position -->
                        <TextBlock Text="Taskbar Position" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="PositionCombo" Width="200" HorizontalAlignment="Left" Margin="0,0,0,20" SelectionChanged="PositionCombo_SelectionChanged">
                            <ComboBoxItem Content="Bottom"/>
                            <ComboBoxItem Content="Top"/>
                            <ComboBoxItem Content="Left"/>
                            <ComboBoxItem Content="Right"/>
                        </ComboBox>

                        <!-- Height / Thickness Slider -->
                        <TextBlock Text="Taskbar Size (pixels)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,10" Width="300" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="HeightSlider" Grid.Column="0" Minimum="20" Maximum="100" Value="48" TickFrequency="2" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Setting_Changed"/>
                            <TextBlock Text="{Binding ElementName=HeightSlider, Path=Value}" Foreground="{StaticResource TextBrush}" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save &amp; Apply" Style="{StaticResource ModernButton}" Background="{StaticResource AccentBrush}" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
