<UserControl x:Class="MonitorFusion.App.Views.WallpaperSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- TBD Styling -->
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,10,0">
            <!-- Header -->
            <TextBlock Text="Wallpaper Settings"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <!-- Target Monitor Selection -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Select Monitor to Configure" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ComboBox x:Name="MonitorSelector" Margin="0,0,0,10" SelectionChanged="MonitorSelector_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FriendlyName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Wallpaper Source Configuration -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Background Image" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Border x:Name="ImagePreviewBorder" Background="#1A1A2E" CornerRadius="4" Height="150" Margin="0,0,0,10" MouseLeftButtonDown="ImagePreview_Click" Cursor="Hand" ClipToBounds="True">
                            <Grid>
                                <Image x:Name="ImagePreview" Stretch="Uniform" Visibility="Collapsed"/>
                                <TextBlock x:Name="ImagePreviewPlaceholder" Text="Click to select image" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <TextBlock Text="Sizing Mode" Foreground="{StaticResource TextBrush}" Margin="0,10,0,5"/>
                        <ComboBox x:Name="SizingCombo" SelectionChanged="Setting_Changed" Margin="0,0,0,15"/>

                        <Button Content="Apply to all Monitors" Style="{StaticResource ModernButton}" Background="#2D2D3F" Foreground="{StaticResource AccentBrush}" Click="ApplyToAll_Click"/>
                    </StackPanel>

                    <!-- Adjustments Sliders -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Adjustments (ImageSharp)" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Brightness" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="BrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Setting_Changed"/>
                            <TextBlock Text="{Binding ElementName=BrightnessSlider, Path=Value, StringFormat={}{0:F1}}" Foreground="{StaticResource TextBrush}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Contrast" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="ContrastSlider" Grid.Column="1" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Setting_Changed"/>
                            <TextBlock Text="{Binding ElementName=ContrastSlider, Path=Value, StringFormat={}{0:F1}}" Foreground="{StaticResource TextBrush}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Blur" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="BlurSlider" Grid.Column="1" Minimum="0" Maximum="20" Value="0" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="Setting_Changed"/>
                            <TextBlock Text="{Binding ElementName=BlurSlider, Path=Value}" Foreground="{StaticResource TextBrush}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <WrapPanel Margin="0,10,0,0">
                            <CheckBox x:Name="GrayscaleCheck" Content="Grayscale" Foreground="{StaticResource TextBrush}" Margin="0,0,15,10" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="SepiaCheck" Content="Sepia" Foreground="{StaticResource TextBrush}" Margin="0,0,15,10" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                            <CheckBox x:Name="InvertCheck" Content="Invert Colors" Foreground="{StaticResource TextBrush}" Margin="0,0,15,10" Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Wallpaper Rotation Configuration -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Automatic Wallpaper Rotation" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <CheckBox x:Name="RotationEnabledCheck" Content="Enable Rotation" Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" Checked="RotationSetting_Changed" Unchecked="RotationSetting_Changed"/>
                    <StackPanel x:Name="RotationSettingsPanel" IsEnabled="{Binding ElementName=RotationEnabledCheck, Path=IsChecked}">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Interval (Minutes)" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="RotationIntervalBox" Grid.Column="1" Text="30" TextChanged="RotationInterval_TextChanged" Padding="4"/>
                        </Grid>
                        <TextBlock Text="Source Folders" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <ListBox x:Name="RotationFoldersList" Height="100" Margin="0,0,0,10" Background="#1A1A2E" Foreground="{StaticResource TextBrush}" BorderThickness="0"/>
                        <WrapPanel>
                            <Button Content="Add Folder" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Click="AddFolder_Click"/>
                            <Button Content="Remove Selected" Style="{StaticResource ModernButton}" Click="RemoveFolder_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save / Apply -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Preview Changes" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Click="Preview_Click"/>
                <Button Content="Save Profile" Style="{StaticResource ModernButton}" Background="{StaticResource AccentBrush}" Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
