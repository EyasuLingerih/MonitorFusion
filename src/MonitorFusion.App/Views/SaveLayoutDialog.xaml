<Window x:Class="MonitorFusion.App.Views.SaveLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Window Layout" Height="200" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Save Window Layout" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Text="Enter a name for this layout:" Grid.Row="1" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
        
        <TextBox x:Name="NameTextBox" Grid.Row="2" Height="30" VerticalContentAlignment="Center"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                 Padding="5,0"/>
                 
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
            <Button Content="Cancel" MinWidth="80" Margin="0,0,10,0" IsCancel="True" Style="{StaticResource ModernButton}"/>
            <Button Content="Save" MinWidth="80" Background="{StaticResource AccentBrush}" Foreground="White"
                    IsDefault="True" Click="Save_Click" Style="{StaticResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
