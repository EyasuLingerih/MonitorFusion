<Window x:Class="MonitorFusion.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="MonitorFusion — Multi-Monitor Management"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.png">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Title Bar Button Styles -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Marlett"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#151520">
            <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                <Image Source="/Assets/icon.png" Width="16" Height="16" Margin="0,0,10,0"/>
                <TextBlock Text="MonitorFusion" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
            <!-- WindowChrome.IsHitTestVisibleInChrome is needed so buttons are clickable -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="0" Width="46" Click="Minimize_Click" Style="{StaticResource TitleBarButton}"/>
                <Button Content="1" x:Name="MaximizeButton" Width="46" Click="Maximize_Click" Style="{StaticResource TitleBarButton}"/>
                <Button Content="r" Width="46" Click="Close_Click" Style="{StaticResource TitleBarCloseButton}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- System Tray Icon (invisible, lives in background) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="/Assets/tray-icon.ico"
                        ToolTipText="MonitorFusion"
                        DoubleClickCommand="{Binding ShowWindowCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Settings" Click="ShowSettings_Click"/>
                    <Separator/>
                    <MenuItem Header="Monitors" x:Name="MonitorsMenu" Click="MonitorsMenu_Click"/>
                    <Separator/>
                    <MenuItem Header="Wallpaper">
                        <MenuItem Header="Next Random Wallpaper" Click="NextWallpaper_Click"/>
                        <Separator/>
                        <!-- Wallpaper profiles will be populated dynamically -->
                    </MenuItem>
                    <MenuItem Header="Window Layouts" x:Name="WindowLayoutsMenu">
                        <MenuItem Header="Save Current Layout As..." Click="SavePositionsAs_Click"/>
                        <Separator/>
                        <!-- Profiles will be populated dynamically -->
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Toggle Focus Mode" Click="ToggleFocusMode_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <StackPanel Margin="0,20,0,0">
                <!-- App Title -->
                <TextBlock Text="MonitorFusion"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold"
                           Margin="20,0,0,20"/>
                <TextBlock Text="v0.1.0 — Open Source"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="20,-15,0,30"/>

                <!-- Navigation Items -->
                <Button Content="🖥️  Monitors" Style="{StaticResource NavButton}"
                        Click="NavMonitors_Click"/>
                <Button Content="🖼️  Wallpaper" Style="{StaticResource NavButton}"
                        Click="NavWallpaper_Click"/>
                <Button Content="📐  Window Snapping" Style="{StaticResource NavButton}"
                        Click="NavSnapping_Click"/>
                <Button Content="⌨️  Hotkeys" Style="{StaticResource NavButton}"
                        Click="NavHotkeys_Click"/>
                <Button Content="📊  Taskbar" Style="{StaticResource NavButton}"
                        Click="NavTaskbar_Click"/>
                <Button Content="🗂️  Window Layouts" Style="{StaticResource NavButton}"
                        Click="NavWindowLayouts_Click"/>
                <Button Content="🌙  Focus Mode" Style="{StaticResource NavButton}"
                        Click="NavFading_Click"/>
                <Button Content="⚙️  Settings" Style="{StaticResource NavButton}"
                        Click="NavSettings_Click"/>

                <!-- GitHub banner -->
                <Border Background="#1A2A1A" CornerRadius="8" Margin="15,40,15,0" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Open Source"
                                   Foreground="#4CAF50"
                                   FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="MonitorFusion is free and open source. Star it on GitHub or contribute!"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" FontSize="11" Margin="0,5,0,8"/>
                        <Button Content="View on GitHub"
                                Style="{StaticResource ModernButton}"
                                Background="#2D4A2D"
                                Click="ViewOnGitHub_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Right Content Area -->
        <ScrollViewer Grid.Column="1" Margin="30,20,30,20"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel">

                <!-- Monitor Overview (default view) -->
                <TextBlock Text="Connected Monitors"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                <!-- Monitor cards will be generated in code-behind -->
                <ItemsControl x:Name="MonitorList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Monitor icon -->
                                    <Border Grid.Column="0" Width="60" Height="40"
                                            Background="#3A3A5A" CornerRadius="4"
                                            Margin="0,0,16,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Index}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="20" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Monitor details -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Foreground="{StaticResource TextBrush}"
                                                   FontSize="16" FontWeight="SemiBold">
                                            <Run Text="{Binding FriendlyName}"/>
                                            <Run Text="{Binding IsPrimary, StringFormat=' {0}'}"
                                                 Foreground="{StaticResource AccentBrush}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13" Margin="0,4,0,0">
                                            <Run Text="{Binding Width, Mode=OneWay}"/>
                                            <Run Text="×"/>
                                            <Run Text="{Binding Height, Mode=OneWay}"/>
                                            <Run Text=" @ "/>
                                            <Run Text="{Binding RefreshRate}"/>
                                            <Run Text="Hz"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DeviceId}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18" FontWeight="Bold" Margin="0,20,0,12"/>

                <WrapPanel>
                    <Button Content="Identify Monitors" Style="{StaticResource ModernButton}"
                            Margin="0,0,10,10" Click="IdentifyMonitors_Click"/>
                    <Button Content="Save Window Positions" Style="{StaticResource ModernButton}"
                            Margin="0,0,10,10" Click="SavePositions_Click"/>
                    <Button Content="Restore Window Positions" Style="{StaticResource ModernButton}"
                            Margin="0,0,10,10" Click="RestorePositions_Click"/>
                    <Button Content="Next Wallpaper" Style="{StaticResource ModernButton}"
                            Margin="0,0,10,10" Click="NextWallpaper_Click"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
    </Grid>
</Window>
