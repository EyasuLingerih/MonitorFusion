<UserControl x:Class="MonitorFusion.App.Views.HotkeySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="Transparent">

    <Grid Margin="0,0,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Global Hotkeys" Grid.Row="0"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Text="Configure keyboard shortcuts that work from anywhere in Windows." 
                   Grid.Row="0" Margin="0,35,0,20" Foreground="{StaticResource TextSecondaryBrush}"/>

        <!-- List of Hotkeys -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <ListView x:Name="HotkeysList" Background="Transparent" BorderThickness="0" 
                      Foreground="{StaticResource TextBrush}" SelectionChanged="HotkeysList_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,5"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Action" Width="250">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ActionName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Current Shortcut" Width="250">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#2A2A40" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="{Binding DisplayString}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Enabled" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled}" Content="" VerticalAlignment="Center" 
                                              Checked="HotkeyEnable_Changed" Unchecked="HotkeyEnable_Changed"
                                              Tag="{Binding ActionId}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Edit Area -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16" 
                x:Name="EditPanel" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Click the box below and press your desired key combination:" 
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                    <TextBox x:Name="ListeningBox" Height="40" FontSize="16" FontFamily="Consolas" 
                             VerticalContentAlignment="Center" Background="#1A1A2E" Foreground="{StaticResource AccentBrush}"
                             BorderThickness="1" BorderBrush="{StaticResource AccentBrush}"
                             IsReadOnly="True" PreviewKeyDown="ListeningBox_PreviewKeyDown" 
                             LostFocus="ListeningBox_LostFocus" GotFocus="ListeningBox_GotFocus"
                             Text="Click here to bind..."/>
                    <TextBlock x:Name="ErrorText" Foreground="#FF5555" Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,0">
                    <Button Content="Clear" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Click="Clear_Click"/>
                    <Button Content="Apply changes" Style="{StaticResource ModernButton}" Background="{StaticResource AccentBrush}" Click="Apply_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
