<UserControl x:Class="MonitorFusion.App.Views.MonitorProfileSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800"
             Background="Transparent"
             Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,10,20">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Monitors"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="MonitorCountLabel"
                               Text="Detecting monitors..."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="&#8635;  Refresh"
                        Style="{StaticResource ModernButton}"
                        Background="#2D2D3F" Foreground="{StaticResource AccentBrush}"
                        VerticalAlignment="Top"
                        Click="Refresh_Click"/>
            </Grid>

            <!-- Live Monitor Cards (populated in code-behind) -->
            <WrapPanel x:Name="MonitorCardsPanel" Margin="0,0,0,4"/>

            <!-- Monitor Arrangement -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                    Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Monitor Arrangement"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Drag monitors to rearrange, then click Apply Layout"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,12"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <Border x:Name="ArrangementBorder"
                                Background="#141420" CornerRadius="4" MinHeight="160" MinWidth="560"/>
                    </ScrollViewer>
                    <Button x:Name="ApplyLayoutBtn"
                            Content="Apply Layout"
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource AccentBrush}"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0" Padding="16,6"
                            Click="ApplyLayout_Click"/>
                </StackPanel>
            </Border>

            <!-- Save Current Layout as Profile -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                    Padding="16" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Save Current Layout as Profile"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Captures resolutions, refresh rates, orientations and positions of all connected monitors."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewProfileNameBox"
                                 Grid.Column="0" Margin="0,0,10,0" Padding="8,6"
                                 FontSize="14" VerticalContentAlignment="Center"
                                 Background="#1A1A2E" Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0" Text="My Layout"/>
                        <Button Grid.Column="1" Content="Save Profile"
                                Style="{StaticResource ModernButton}"
                                Background="{StaticResource AccentBrush}"
                                Click="SaveProfile_Click" Padding="16,8"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Saved Profiles -->
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="Saved Profiles"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <ListView x:Name="ProfilesList"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource TextBrush}" MinHeight="60"
                              SelectionChanged="ProfilesList_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3A3A5A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Profile Name" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Displays" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Displays.Count}"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Saved" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=g}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Actions" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Apply"
                                                        Style="{StaticResource ModernButton}"
                                                        Background="{StaticResource AccentBrush}"
                                                        Padding="12,4" Margin="0,0,8,0"
                                                        Click="ApplyProfile_Click"
                                                        Tag="{Binding Name}"/>
                                                <Button Content="Delete"
                                                        Style="{StaticResource ModernButton}"
                                                        Background="#3D1A1A" Foreground="#FF6B6B"
                                                        Padding="12,4"
                                                        Click="DeleteProfile_Click"
                                                        Tag="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock x:Name="NoProfilesLabel"
                               Text="No profiles saved yet. Set up your monitors in Windows Display Settings, then click 'Save Profile' above."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" FontSize="13"
                               Margin="0,10,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
